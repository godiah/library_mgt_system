<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <%= image_tag "logo.png", alt: "Logo", class: "h-12 w-auto mx-auto" %>
        <h2 class="mt-4 text-center text-2xl/9 font-bold tracking-tight text-gray-900">Sign in to your account</h2>
    </div>

    <div class="mt-4 sm:mx-auto sm:w-full sm:max-w-sm">
        <%= form_with url: sign_in_path, class: "space-y-6" do |form| %>
        <div>
            <%= form.label :email, class: "block text-sm/6 font-medium text-gray-900" %>
            <div class="mt-2">
                <%= form.email_field :email, 
                autocomplete: "email",
                required: true,
                placeholder: "johndoe@gmail.com",
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
            </div>
        </div>

        <div>
            <div class="flex items-center justify-between">
                <%= form.label :password, class: "block text-sm/6 font-medium text-gray-900" %>
            </div>
            <div class="mt-2">
                <%= form.password_field :password,
                autocomplete: "current-password",
                required: true,
                placeholder: "********",
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
            </div>
        </div>

        <div>
            <%= form.submit "Sign in", 
              class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
        <% end %>

        <p class="mt-10 text-center text-sm/6 text-gray-500">
            Don't have an account yet?
            <%= link_to "Sign up", sign_up_path, class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
        </p>
    </div>
</div>