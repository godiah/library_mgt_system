<div>
    <%= render partial: "shared/navbar" %>
</div>

<div class="container mx-auto px-4 py-6">
    <div class="max-w-md mx-auto bg-white rounded-lg shadow overflow-hidden">
        <div class="p-6">
            <div class="flex items-center mb-4">
                <!-- Book SVG Icon -->
                <svg class="w-10 h-10 text-indigo-600 mr-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                    <!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
                    <path fill="#363ab0" d="M96 0C43 0 0 43 0 96L0 416c0 53 43 96 96 96l288 0 32 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l0-64c17.7 0 32-14.3 32-32l0-320c0-17.7-14.3-32-32-32L384 0 96 0zm0 
                384l256 0 0 64L96 448c-17.7 0-32-14.3-32-32s14.3-32 32-32zm32-240c0-8.8 7.2-16 16-16l192 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-192 0c-8.8 0-16-7.2-16-16zm16 48l192 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-192 0c-8.8 0-16-7.2-16-16s7.2-16 16-16z" />
                </svg>
                <h2 class="text-2xl font-semibold text-gray-900"><%= @book.title %></h2>
            </div>
            <p class="text-gray-700 mb-2"><strong>Author:</strong> <%= @book.author %></p>
            <p class="text-gray-700 mb-2"><strong>ISBN:</strong> <%= @book.isbn %></p>
            <p class="text-gray-700 mb-4">
                <strong>Status:</strong>
                <% if @book.borrowed_by?(Current.user) %>
                <span class="bg-red-100 text-red-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded-sm">
                    Borrowed
                </span>
                <% else %>
                <span class="bg-green-100 text-green-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded-sm">
                    Available
                </span>
                <% end %>
            </p>

            <% if @book.borrowed_by?(Current.user) %>
            <%= button_to "Return", return_book_path(@book), method: :post,
          class: "block mx-auto w-full sm:w-1/2 bg-green-600 hover:bg-green-500 text-white px-4 py-2 rounded" %>
            <% else %>
            <%= button_to "Borrow", borrow_book_path(@book), method: :post,
          class: "block mx-auto w-full sm:w-1/2 bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded" %>
            <% end %>
        </div>
    </div>
</div>