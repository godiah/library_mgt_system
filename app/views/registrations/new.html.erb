<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <%= image_tag "logo.png", alt: "Logo", class: "h-12 w-auto mx-auto" %>
        <h2 class="mt-4 text-center text-2xl/9 font-bold tracking-tight text-gray-900">Sign up for an account</h2>
    </div>

    <div class="mt-4 sm:mx-auto sm:w-full sm:max-w-sm">
        <%# Add error messages at the top of the form %>
        <% if @user.errors.any? %>
        <div class="mb-4 rounded-md border border-red-400 bg-red-50 p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">
                        <%= pluralize(@user.errors.count, "error") %> prevented your account from being created:
                    </h3>
                    <div class="mt-2 text-sm text-red-700">
                        <ul class="list-disc space-y-1 pl-5">
                            <% @user.errors.full_messages.each do |msg| %>
                            <li><%= msg %></li>
                            <% end %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <% end %>

        <%= form_with model: @user, url: sign_up_path, class: "space-y-6" do |form| %>
        <div>
            <%= form.label :email, class: "block text-sm/6 font-medium text-gray-900" %>
            <div class="mt-2">
                <%= form.email_field :email, 
                autocomplete: "email",
                required: true,
                placeholder: "johndoe@gmail.com",
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 #{@user.errors[:email].any? ? 'outline-red-500' : 'outline-gray-300'} placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
                <% if @user.errors[:email].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @user.errors[:email].join(', ') %></p>
                <% end %>
            </div>
        </div>

        <div>
            <div class="flex items-center justify-between">
                <%= form.label :password, class: "block text-sm/6 font-medium text-gray-900" %>
            </div>
            <div class="mt-2">
                <%= form.password_field :password,
                autocomplete: "new-password",
                required: true,
                placeholder: "********",
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 #{@user.errors[:password].any? ? 'outline-red-500' : 'outline-gray-300'} placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
                <% if @user.errors[:password].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @user.errors[:password].join(', ') %></p>
                <% end %>
            </div>
        </div>

        <div>
            <%= form.label :password_confirmation, class: "block text-sm/6 font-medium text-gray-900" %>
            <div class="mt-2">
                <%= form.password_field :password_confirmation,
                autocomplete: "new-password",
                required: true,
                placeholder: "********",
                class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 #{@user.errors[:password_confirmation].any? ? 'outline-red-500' : 'outline-gray-300'} placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
                <% if @user.errors[:password_confirmation].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @user.errors[:password_confirmation].join(', ') %></p>
                <% end %>
            </div>
        </div>

        <div>
            <%= form.submit "Sign up", 
              class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
        <% end %>

        <p class="mt-10 text-center text-sm/6 text-gray-500">
            Already have an account?
            <%= link_to "Sign in", sign_in_path, class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
        </p>
    </div>
</div>